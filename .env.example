XRAY_CLIENT_ID=your_client_id_here
XRAY_CLIENT_SECRET=your_client_secret_here

# HTTP port the server listens on (default: 3000)
PORT=3000

# Comma-separated Host headers to accept - add your domain when deploying remotely
# Defaults to localhost:<PORT>,127.0.0.1:<PORT> if not set
ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000

# Bind address (default: 127.0.0.1). Set to 0.0.0.0 behind a reverse proxy.
# HOST=0.0.0.0

# Maximum concurrent MCP sessions before new ones are rejected (default: 100)
# MAX_SESSIONS=100

# Idle time (ms) before an inactive session is swept and closed (default: 1800000 = 30 min)
# SESSION_IDLE_MS=1800000

# Reverse-proxy hops to trust for client IP (default: 0). Set to 1 behind nginx/Caddy.
# TRUST_PROXY=1